# ============================================================
# 品猹 (Pingcha) 环境变量配置
# 复制本文件为 .env 并填写必要配置
# ============================================================

# ─── 基础设施（Docker Compose 默认值，本地开发可不改）──────────
DATABASE_URL=postgresql+asyncpg://postgres:postgres@db:5432/pingcha
POSTGRES_DB=pingcha
POSTGRES_PASSWORD=postgres
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin

# ─── 安全配置（生产环境必须修改！）─────────────────────────────
# JWT 签名密钥，至少 32 字符随机字符串（必填，留空将导致启动失败）
# 生成方式: python -c "import secrets; print(secrets.token_urlsafe(32))"
JWT_SECRET_KEY=

# 管理后台 Token
ADMIN_TOKEN=

# ─── AI 功能（TokenDance 一站式配置）─────────────────────────
# TokenDance 是品猹推荐的 AI 网关，一个 API Key 即可使用：
#   - LLM 摘要 / Wiki 编译 / 知识追问
#   - 文本向量化 (Embedding)
#   - Whisper 语音识别 (ASR)
#
# 注册地址：https://tokendance.space
# 获取 API Key 后填入下方即可启用全部 AI 功能
OPENAI_API_KEY=sk-your-tokendance-api-key
SUMMARY_API_BASE=https://tokendance.space/gateway/v1

# 摘要模型（TokenDance 支持的模型列表见其文档）
SUMMARY_MODEL=openai/deepseek-v4-flash
FAST_SUMMARY_MODEL=openai/deepseek-v4-flash
DEEP_SUMMARY_MODEL=openai/deepseek-v4-flash
WIKI_COMPILER_MODEL=openai/deepseek-v4-flash

# Embedding（留空则复用 SUMMARY_API_BASE + OPENAI_API_KEY）
EMBEDDING_MODEL=openai/text-embedding-v3
EMBEDDING_API_BASE=
EMBEDDING_API_KEY=

# Whisper ASR（留空则复用 SUMMARY_API_BASE + OPENAI_API_KEY）
# 如果 TokenDance 支持 Whisper 端点，填入相同地址即可
WHISPER_API_BASE=
WHISPER_API_KEY=

# ─── 字幕获取（YouTube 视频字幕提取）────────────────────────
# 品猹使用多级降级策略获取字幕，优先级从高到低：
#   1. TikHub（推荐，国内可直连，0.001元/次）
#   2. youtube-transcript-api（免费本地库，需代理访问 YouTube）
#   3. yt-dlp 平台字幕（免费，需代理）
#   4. ASR 语音识别兜底（消耗较多 token）
#
# 推荐：注册 TikHub（https://tikhub.io）获取 API Key
# TikHub 服务端代理 YouTube，无需本地翻墙即可获取字幕
TIKHUB_API_KEY=

# 以下为可选的备用字幕服务（一般不需要配置）
# SUPADATA_API_KEY=
# TRANSCRIPTAPI_API_KEY=
# TRANSCRIPTHQ_API_KEY=

# ─── YouTube 访问（yt-dlp / 音频下载用）────────────────────
# 如果不配置 TikHub，yt-dlp 需要代理才能访问 YouTube
# YOUTUBE_PROXY=http://127.0.0.1:7897
# YOUTUBE_COOKIES_PATH=/app/cookies/cookies.txt

# ─── 播客 ASR（可选，仅处理播客音频时需要）────────────────────
# 讯飞录音文件转写（支持说话人分离，适合播客对话）
# XFYUN_APP_ID=
# XFYUN_ACCESS_KEY_ID=
# XFYUN_API_SECRET=

# 火山引擎 ASR（极速版，适合短视频）
# VOLC_ASR_APP_ID=
# VOLC_ASR_ACCESS_TOKEN=

# ─── 观猹 OAuth2（认证系统）──────────────────────────────────
# 在观猹平台创建应用后填入（如不使用观猹认证可跳过）
WATCHA_CLIENT_ID=
WATCHA_CLIENT_SECRET=
WATCHA_REDIRECT_URI=http://localhost:8000/api/v1/auth/callback
# 猹选模块抓取观猹内容/产品 API 的基础地址（替换数据源时可改）
WATCHA_API_BASE=https://watcha.cn

# ─── 前端 ─────────────────────────────────────────────────
FRONTEND_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:8000

# ─── 可选：监控与通知 ──────────────────────────────────────
# Sentry（错误追踪）
# SENTRY_DSN=
# NEXT_PUBLIC_SENTRY_DSN=

# Resend（邮件通知）
# RESEND_API_KEY=
