# Database
DATABASE_URL=postgresql+asyncpg://postgres:postgres@db:5432/pingcha
POSTGRES_DB=pingcha
POSTGRES_PASSWORD=postgres

# Redis
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1

# MinIO
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin

# LLM
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
DEEPSEEK_API_KEY=

# ASR
ALIYUN_ASR_APP_KEY=
# 讯飞录音文件识别（播客 ASR，支持说话人分离）
XFYUN_APP_ID=
XFYUN_API_SECRET=

# Admin
ADMIN_TOKEN=

# 观猹 OAuth2 (机密客户端)
# 在观猹平台创建应用后填入
WATCHA_CLIENT_ID=your_client_id_here
WATCHA_CLIENT_SECRET=your_client_secret_here
WATCHA_REDIRECT_URI=http://localhost:8000/api/v1/auth/callback

# Session JWT signing key — use a long random string in production
JWT_SECRET_KEY=changeme-use-a-long-random-secret

# Frontend base URL (for post-login redirect and CORS)
FRONTEND_URL=http://localhost:3000

# Curate module
RESEND_API_KEY=
PRODUCT_HUNT_API_KEY=
TIKHUB_API_KEY=

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:8000

# Sentry (性能监控 & 错误追踪) — 在 sentry.io 创建项目后填入
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=

# 代理配置（可选，中国大陆访问 YouTube 需要）
# HTTP_PROXY=http://your-proxy-server:port
# HTTPS_PROXY=http://your-proxy-server:port
# YOUTUBE_PROXY=http://your-proxy-server:port
